# Telegram bot token — get yours from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ============================================================================
# CLOUD DEPLOYMENT (Render.com)
# ============================================================================
# Set this to your Render service URL to enable webhook mode.
# When empty, the bot uses polling mode (default for local/PC).
#
# Render example:  WEBHOOK_BASE_URL=https://tg-instagram-bot.onrender.com
#
# Leave empty to keep using polling mode (local PM2/PC).
# WEBHOOK_BASE_URL=
#
# Port for the Express webhook server (default: 3000)
# PORT=3000

# ============================================================================
# 24/7 UPTIME — Keep-Alive Settings
# ============================================================================
# Built-in self-pinger prevents Render free-tier idle spin-down (15-min threshold).
# The bot pings its own /health endpoint every 10 minutes to stay "warm" 24/7.
#
# KEEP_ALIVE=true           # Enable self-pinger (default: true on Render)
# KEEP_ALIVE=false          # Disable (bot will sleep after 15 min of inactivity)
# KEEP_ALIVE_INTERVAL_MS=600000  # Ping interval in ms (default: 600000 = 10 min)
#
# For external uptime monitors (UptimeRobot, Cron-job.org, Freshping):
# Point them to: GET https://YOUR-APP.onrender.com/ping
# The /ping endpoint returns JSON: { status, uptime, timestamp, mode }

# ============================================================================
# PROXY CONFIGURATION (for Instagram registration — prevents IP-based bans)
# ============================================================================
#
# TWO OPTIONS — pick ONE:
#
# Option A: Multiple providers (RECOMMENDED)
#   Set PROXY_PROVIDERS with one entry per provider, separated by ; or newlines.
#   Format: TYPE|host:port|username|password|zone|label
#
#   TYPE can be: residential | static | socks5 | api
#     residential = HTTP rotating residential proxy with country zones
#     static      = HTTP static IP pool
#     socks5      = SOCKS5 proxy (best for Instagram)
#     api         = API endpoint that returns a fresh proxy per request
#
# Option B: Legacy single provider
#   Set PROXY_HOST, PROXY_PORT, PROXY_USER, PROXY_PASS, PROXY_ZONE (optional).
#   This is backward-compatible with existing configs.
#
# Rotation Modes:
#   PROXY_ROTATION_MODE=random         (default — pick any healthy provider)
#   PROXY_ROTATION_MODE=round-robin    (cycle through providers in order)
#   PROXY_ROTATION_MODE=best-latency   (use the fastest responding provider)
# ============================================================================

# --- Option A: Multi-provider (recommended) ---
# Uncomment and fill in for your proxy service(s):

# EXAMPLE 1: BrightData residential proxies
# PROXY_PROVIDERS=residential|brd.superproxy.io:22225|brd-customer-XXX-zone-YYY|PASSWORD|YYY|BrightData

# EXAMPLE 2: Webshare residential proxies
# PROXY_PROVIDERS=residential|p.webshare.io:80|USERNAME-rotate-REGION-us|PASSWORD||Webshare

# EXAMPLE 3: IPRoyal residential proxies
# PROXY_PROVIDERS=residential|geo.iproyal.com:12321|USERNAME_country-us|PASSWORD||IPRoyal

# EXAMPLE 4: Oxylabs residential proxies
# PROXY_PROVIDERS=residential|pr.oxylabs.io:7777|customer-USERNAME-cc-us|PASSWORD||Oxylabs

# EXAMPLE 5: Proxy-Cheap residential proxies
# PROXY_PROVIDERS=residential|proxy.proxy-cheap.com:31112|USERNAME-region-us|PASSWORD||ProxyCheap

# EXAMPLE 6: Your own SOCKS5 proxy
# PROXY_PROVIDERS=socks5|192.168.1.100:1080|username|password||LocalSOCKS5

# EXAMPLE 7: Multiple providers with failover
# PROXY_PROVIDERS=residential|brd.superproxy.io:22225|CUSTOMER|PASS|zone|BrightData;socks5|res.proxy.com:1080|user|pass||BackupSOCKS5

# EXAMPLE 8: API-based rotating proxy (fetches fresh proxy per request)
# PROXY_PROVIDERS=api|https://api.proxyservice.com/get?token=XXX|||APIrotator

# PROXY_ROTATION_MODE=random

# --- Option B: Legacy single provider ---
# PROXY_HOST=43.131.1.47
# PROXY_PORT=4950
# PROXY_USER=Abhix1526ZY2013
# PROXY_PASS=AbhiTamu1526
# PROXY_ZONE=abc

# --- Common settings (both options) ---
# PROXY_DEFAULT_COUNTRY=us
# PROXY_PREFLIGHT_CHECK=true         # Test proxy before using (set false to disable)
# PROXY_HEALTH_TIMEOUT_MS=12000      # Max ms to wait for health check
# PROXY_MAX_FAILURES=3               # Consecutive failures before marking unhealthy

# --- Best-proxy auto-selection (for /proxy with no country or "email|proxy") ---
# Runs LIVE parallel health checks on ALL providers and picks the fastest one.
# PROXY_BEST_LATENCY_THRESHOLD_MS=300   # Max acceptable latency; providers above this are skipped (default 300ms)
# PROXY_BEST_LATENCY_TIMEOUT_MS=10000   # Timeout per provider during live check (default 10000ms)

# ============================================================================
# WHATSAPP REGISTRATION
# ============================================================================

# Registration provider:
# - pairing: link an existing WhatsApp account as a companion device
# - meta-cloud: request/verify OTP through the official Meta WhatsApp Business Cloud API
WHATSAPP_REGISTRATION_PROVIDER=pairing

# Required when WHATSAPP_REGISTRATION_PROVIDER=meta-cloud
# META_ACCESS_TOKEN=your_meta_access_token
# META_GRAPH_VERSION=v23.0
#
# Use either an existing Phone Number ID:
# META_PHONE_NUMBER_ID=123456789012345
#
# Or allow the bot to add fresh numbers to a WABA:
# META_WABA_ID=123456789012345
# META_VERIFIED_NAME=Your Business Display Name
#
# Required to call the Cloud API register endpoint:
# META_TWO_STEP_PIN=123456
# META_VERIFY_LANGUAGE=en_US

# Optional: auth state directory (default: auth_state)
# AUTH_STATE_DIR=auth_state

# Optional: pairing code lifetime in milliseconds (default: 120000)
# PAIRING_TIMEOUT_MS=120000

# Optional: browser description for Baileys
# BROWSER_DESCRIPTION=Desktop
